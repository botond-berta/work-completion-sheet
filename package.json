    "drizzle-orm": "^0.45.2",
    "lucide-react": "^1.22.0",
    "next": "16.2.9",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "shadcn": "^4.12.0",
    "tailwind-merge": "^3.6.0",
    "tsx": "^4.22.4"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
